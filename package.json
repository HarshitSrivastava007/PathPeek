{
  "name": "pathpeek",
  "displayName": "PathPeek",
  "description": "See full file paths and preview files on hover. Click or Cmd+Click to navigate instantly.",
  "version": "0.0.2",
  "author": {
    "name": "Harshit Srivastava"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "path",
    "hover",
    "file preview",
    "navigation",
    "import",
    "developer tools"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "images/logo.png",
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/HarshitSrivastava007/pathpeek.git"
  },
  "homepage": "https://github.com/HarshitSrivastava007/pathpeek",
  "bugs": {
    "url": "https://github.com/HarshitSrivastava007/pathpeek/issues"
  },
  "contributes": {
    "configuration": {
      "title": "PathPeek",
      "properties": {
        "hoverPath.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable PathPeek hover preview"
        },
        "hoverPath.previewLines": {
          "type": "number",
          "default": 10,
          "description": "Number of lines to preview"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}